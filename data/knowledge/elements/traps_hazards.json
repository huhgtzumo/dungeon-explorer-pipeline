  {"id": "th_004", "name_zh": "洪水灌入", "name_en": "Flooding", "description_zh": "管道破裂或閘門開啟導致水位迅速上漲，必須在被淹沒前找到高處或出口。", "tags": ["環境危險", "水"]},
  {"id": "th_005", "name_zh": "結構不穩", "name_en": "Structural Instability", "description_zh": "整個區域的支撐結構在搖晃，隨時可能完全坍塌，必須在時間壓力下通過。", "tags": ["結構危險", "經典"]},
  {"id": "th_006", "name_zh": "野生動物", "name_en": "Wild Animals", "description_zh": "在黑暗中遭遇棲息在廢墟中的野生動物——流浪狗群、蝙蝠群或蛇，牠們把這裡當作領地。", "tags": ["環境危險", "生物"]},
  {"id": "th_007", "name_zh": "斷電黑暗", "name_en": "Power Failure", "description_zh": "僅有的電力突然中斷，所有光源和電子設備停止工作，陷入完全的黑暗。", "tags": ["環境危險", "黑暗"]},
  {"id": "th_008", "name_zh": "天花板崩落", "name_en": "Ceiling Collapse", "description_zh": "頭頂傳來碎裂聲，混凝土或木材碎片開始掉落，必須快速通過危險區域。", "tags": ["結構危險", "墜落物"]},
  {"id": "th_009", "name_zh": "積水觸電", "name_en": "Electrified Water", "description_zh": "地面積水中有裸露的電線，火花在水面上跳動，必須找到繞行或斷電的方法。", "tags": ["環境危險", "高危"]},
  {"id": "th_010", "name_zh": "階梯斷裂", "name_en": "Broken Stairway", "description_zh": "樓梯突然斷裂或缺失幾階，面前是黑暗的間隙，需要冒險跳過或尋找替代路線。", "tags": ["結構危險", "墜落"]},
  {"id": "th_011", "name_zh": "有毒黴菌", "name_en": "Toxic Mold", "description_zh": "牆壁和天花板覆蓋著大片黑色黴菌，孢子在空氣中漂浮，長時間暴露會引起幻覺。", "tags": ["環境危險", "生物"]},
  {"id": "th_012", "name_zh": "機關陷阱", "name_en": "Mechanism Trap", "description_zh": "踩到壓力板或觸動機關線，觸發隱藏的陷阱——可能是落石、鐵柵或突然關閉的通道。", "tags": ["機關陷阱", "人為"]},
  {"id": "th_013", "name_zh": "密室缺氧", "name_en": "Sealed Room Suffocation", "description_zh": "密封空間中的氧氣逐漸消耗，呼吸變得困難，思維開始模糊，必須盡快找到出口。", "tags": ["環境危險", "封閉"]},
  {"id": "th_014", "name_zh": "旋轉牆壁", "name_en": "Rotating Wall", "description_zh": "靠在牆上時牆壁突然旋轉，被帶入完全不同的房間，原來的位置已經封閉。", "tags": ["機關陷阱", "迷失"]},
  {"id": "th_015", "name_zh": "隱蔽深坑", "name_en": "Hidden Pit", "description_zh": "被碎片或積水覆蓋的地面下是深不見底的坑洞，一步之差就會跌入深淵。", "tags": ["結構危險", "墜落"]},
  {"id": "th_016", "name_zh": "倒計時裝置", "name_en": "Countdown Device", "description_zh": "發現一個正在倒計時的電子裝置或機械鐘錶，不知道歸零時會發生什麼。", "tags": ["機關陷阱", "緊迫"]},
  {"id": "th_017", "name_zh": "化學品洩漏", "name_en": "Chemical Spill", "description_zh": "容器破裂導致腐蝕性化學品流淌在地面上，接觸會造成灼傷，需要小心繞行。", "tags": ["環境危險", "高危"]},
  {"id": "th_018", "name_zh": "碎玻璃陷阱", "name_en": "Broken Glass Trap", "description_zh": "大量碎玻璃覆蓋地面，在黑暗中幾乎不可見，每一步都可能割傷。", "tags": ["環境危險", "潛伏"]},
  {"id": "th_019", "name_zh": "鬆動管道", "name_en": "Loose Piping", "description_zh": "頭頂的管道鬆動搖搖欲墜，隨時可能砸落，蒸汽從接縫處噴射。", "tags": ["結構危險", "墜落物"]},
  {"id": "th_020", "name_zh": "電梯故障", "name_en": "Elevator Malfunction", "description_zh": "搭乘的電梯突然停止並開始異常搖晃，困在樓層之間的密封空間中。", "tags": ["機關陷阱", "封閉"]},
  {"id": "th_021", "name_zh": "石棉暴露", "name_en": "Asbestos Exposure", "description_zh": "破損的隔熱材料釋放石棉纖維到空氣中，肉眼難以發覺但極度危害健康。", "tags": ["環境危險", "隱形"]},
  {"id": "th_022", "name_zh": "護欄缺失", "name_en": "Missing Railing", "description_zh": "高處的走廊或樓梯護欄已經脫落，稍有不慎就會墜落到下方樓層。", "tags": ["結構危險", "墜落"]},
  {"id": "th_023", "name_zh": "活動地板", "name_en": "Moving Floor Panel", "description_zh": "看似穩固的地板在踩上後開始傾斜或滑動，像蹺蹺板一樣失去平衡。", "tags": ["機關陷阱", "經典"]},
  {"id": "th_024", "name_zh": "塵爆風險", "name_en": "Dust Explosion Risk", "description_zh": "空氣中瀰漫著可燃粉塵，任何火花都可能引發爆炸，手電筒開關都變得危險。", "tags": ["環境危險", "高危"]},
  {"id": "th_025", "name_zh": "通道縮窄", "name_en": "Narrowing Passage", "description_zh": "通道越走越窄，最終只能側身通過，卡在中間進退不得的幽閉恐懼。", "tags": ["結構危險", "幽閉"]},
  {"id": "th_026", "name_zh": "鏽蝕鐵釘", "name_en": "Rusty Nails", "description_zh": "散落在地面或從木板突出的鏽蝕鐵釘，踩到會造成穿刺傷和感染風險。", "tags": ["環境危險", "潛伏"]},
  {"id": "th_027", "name_zh": "溫度極端", "name_en": "Extreme Temperature", "description_zh": "特定區域的溫度極端偏高或偏低，長時間暴露會造成中暑或失溫。", "tags": ["環境危險", "環境"]},
  {"id": "th_028", "name_zh": "懸吊物墜落", "name_en": "Hanging Object Falls", "description_zh": "吊燈、管道或天花板裝飾物在頭頂搖搖欲墜，一陣震動後轟然墜落。", "tags": ["結構危險", "墜落物"]},
  {"id": "th_029", "name_zh": "地面塌方", "name_en": "Ground Cave-In", "description_zh": "腳下的地面突然大面積塌陷，露出下方的地下空間或蓄水池。", "tags": ["結構危險", "大規模"]},
  {"id": "th_030", "name_zh": "鎖鏈絆倒", "name_en": "Chain Trip Wire", "description_zh": "在黑暗中橫跨通道的鏽蝕鎖鏈，絆倒後連鎖反應觸發周圍的不穩定結構。", "tags": ["機關陷阱", "連鎖"]}
]
